<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>7cfc573c-0b61-40cd-84e0-837676d9b5b6</ProjectGuid>
    <ProjectHome>
    </ProjectHome>
    <StartupFile>
    </StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>CivTrack</Name>
    <RootNamespace>PythonApplication1</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Admin.py" />
    <Compile Include="Comment.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="incident_status.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="app.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="Report.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="supabase_client.py" />
    <Compile Include="Timestamp.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="User.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="static\" />
    <Folder Include="static\uploads\" />
    <Folder Include="templates\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="static\style.css" />
    <Content Include="templates\admin.html" />
    <Content Include="templates\index.html" />
    <Content Include="templates\reports.html" />
    <Content Include="templates\report_detail.html" />
    <Content Include="templates\stats.html" />
    <Content Include="templates\thank_you.html" />
    <Content Include="templates\user_created.html" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
